<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Birongo | DJ & Music Production</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #000; color: #fff; font-family: 'Arial', sans-serif; }
        .hero-section { height: 80vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1571266028243-3716f02d2d2e?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80'); background-size: cover; text-align: center; }
        .birongo-title { font-size: 5rem; font-weight: bold; letter-spacing: 10px; color: #00ffcc; text-shadow: 0 0 20px #00ffcc; }
        .section-padding { padding: 80px 0; }
        .card { background: #111; border: 1px solid #333; color: #fff; }
        .video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; }
        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">BIRONGO</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="#eventos">Eventos</a>
                <a class="nav-link" href="#videos">Sets</a>
                <a class="nav-link" href="#fotos">Galería</a>
            </div>
        </div>
    </nav>

    <header class="hero-section">
        <div>
            <h1 class="birongo-title">BIRONGO</h1>
            <p class="lead">Cultura de DJ & Producción Musical</p>
        </div>
    </header>

    <section id="eventos" class="container section-padding">
        <h2 class="text-center mb-5">Próximos Eventos</h2>
        <div class="table-responsive">
            <table class="table table-dark table-hover">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Lugar</th>
                        <th>DJ / Productor</th>
                        <th>Tickets</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>15 Oct 2026</td>
                        <td>Club Nocturno XYZ</td>
                        <td>DJ Birongo Master</td>
                        <td><a href="#" class="btn btn-sm btn-outline-info">Comprar</a></td>
                    </tr>
                    </tbody>
            </table>
        </div>
    </section>

    <section id="videos" class="bg-dark section-padding">
        <div class="container text-center">
            <h2 class="mb-5">Video Sets</h2>
            <div class="row">
                <div class="col-md-8 mx-auto">
                    <div class="video-container">
                        <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>
                    </div>
                    <p class="mt-3">Live Set @ Caracas 2026</p>
                </div>
            </div>
        </div>
    </section>

    <section id="fotos" class="container section-padding">
        <h2 class="text-center mb-5">Galería</h2>
        <div class="row g-3">
            <div class="col-6 col-md-4"><img src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?auto=format&fit=crop&w=500&q=60" class="img-fluid rounded" alt="Fiesta"></div>
            <div class="col-6 col-md-4"><img src="https://images.unsplash.com/photo-1516280440614-37939bbacd81?auto=format&fit=crop&w=500&q=60" class="img-fluid rounded" alt="Consola"></div>
            <div class="col-6 col-md-4"><img src="https://images.unsplash.com/photo-1493225255756-d9584f8606e9?auto=format&fit=crop&w=500&q=60" class="img-fluid rounded" alt="Público"></div>
        </div>
    </section>

    <footer class="text-center py-4 border-top border-secondary">
        <p>&copy; 2026 Birongo Music. Todos los derechos reservados.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
